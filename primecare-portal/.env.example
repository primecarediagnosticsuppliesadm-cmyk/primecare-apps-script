# Copy to .env.local for local development (never commit .env.local).
#
# Apps Script proxy (required for local /api/primecare when Supabase is unavailable)
PRIMECARE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
VITE_PRIMECARE_PROXY_URL=/api/primecare

# Supabase (required for Forecast/Reorder reads from v_reorder_candidates, inventory ledger, etc.)
# Get values from Supabase Dashboard → Project Settings → API
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional QA flags
# VITE_APP_ENV=qa
# VITE_ENABLE_LEGACY_APPS_SCRIPT=true
# VITE_PREDATOR_DEBUG=true
